# Expo Goの実機で確認する場合、localhostではなく開発機のLAN IPを指定する
# 例: EXPO_PUBLIC_API_URL=http://192.168.1.10:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
EXPO_PUBLIC_WEB_URL=http://localhost:3002
# RevenueCatダッシュボード > Project settings > API keys の「Public app-specific API key」(iOS)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...
